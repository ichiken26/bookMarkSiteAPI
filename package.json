{
  "name": "bookMarkSiteAPI",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "vite",
    "build": "vite build",
    "preview": "$npm_execpath run build && vite preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:migrate:local": "wrangler d1 migrations apply bookmarksiteapi --local",
    "db:migrate:remote": "wrangler d1 migrations apply bookmarksiteapi --remote"
  },
  "dependencies": {
    "hono": "^4.12.15"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.2.3",
    "@cloudflare/vitest-pool-workers": "^0.15.1",
    "typescript": "^6.0.3",
    "vite": "^6.3.5",
    "vite-ssr-components": "^0.6.1",
    "vitest": "^4.1.5",
    "wrangler": "^4.17.0"
  }
}
